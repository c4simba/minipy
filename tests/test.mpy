class Counter:
    def __init__(self, start):
        self.value = start

    def inc(self):
        self.value = self.value + 1
        return self.value

c = Counter(5)
print(c.inc())
print(c.inc())

def local_test(x):
    y = x + 1
    return y

print(local_test(9))
