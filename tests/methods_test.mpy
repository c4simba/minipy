# Group 6: type methods
# --- string methods ---
print("Hello".upper())
print("Hello".lower())
print("hello world".capitalize())
print("   spaced   ".strip())
print("xxhelloxx".strip("x"))
print("  left".lstrip())
print("right  ".rstrip() + ".")
print("a,b,c,d".split(","))
print("  one  two   three  ".split())
print("-".join(["2024", "01", "15"]))
print("mississippi".replace("s", "S"))
print("aaaa".replace("a", "b", 2))
print("hello world".find("world"))
print("hello".find("z"))
print("banana".count("na"))
print("hello.py".endswith(".py"))
print("hello.py".startswith("hello"))
print("12345".isdigit())
print("abcXYZ".isalpha())
print("   ".isspace())
print("Hello World Foo".lower().split(" "))

# --- list methods ---
nums = [3, 1, 2]
nums.append(5)
print(nums)
nums.sort()
print(nums)
nums.reverse()
print(nums)
print(nums.pop())
print(nums)
nums.insert(0, 99)
print(nums)
nums.extend([7, 8])
print(nums)
print(nums.index(99))
print([1, 2, 2, 3, 2].count(2))
nums.remove(99)
print(nums)
copy = [1, 2].copy()
copy.append(3)
print(copy)

# --- dict methods ---
d = {"a": 1, "b": 2}
print(d.get("a"))
print(d.get("z", -1))
print(sorted(d.keys()))
print(sorted(d.values()))
print(sorted(d.items()))
d.update({"c": 3})
print(sorted(d.keys()))
print(d.setdefault("a", 100))
print(d.setdefault("x", 100))
print(d.pop("b"))
print(sorted(d.keys()))

# --- set methods ---
s = {1, 2, 3}
s.add(4)
print(sorted(s))
s.discard(2)
print(sorted(s))
print(sorted({1, 2, 3}.union({3, 4, 5})))
print(sorted({1, 2, 3}.intersection({2, 3, 4})))
print(sorted({1, 2, 3}.difference({2})))
