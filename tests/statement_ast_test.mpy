import utils
from utils import twice as twice_alias

pass

x = 0
if x == 0:
    print("if")
else:
    print("bad")

while x < 3:
    x += 1
    if x == 2:
        continue
    print(x)
else:
    print("while else")

for v in [1, 2, 3]:
    if v == 2:
        break
    print(v)
else:
    print("bad for else")

def f(a):
    y = a + 1
    return y

class Box:
    def __init__(self, value):
        self.value = value
    def get(self):
        return self.value

b = Box(9)
print(f(4))
print(b.get())
print(utils.answer)
print(twice_alias(3))

with "ctx" as c:
    print(c)

del c
print(c)
