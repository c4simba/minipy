print("for over list")
s = 0
for x in [1, 2, 3, 4]:
    s = s + x
print(s)

print("for over string")
out = ""
for ch in "abc":
    out = out + ch + "-"
print(out)

print("for over dict")
d = {"a": 10, "b": 20}
keys = ""
for k in d:
    keys = keys + k
print(len(keys))

print("bool ops")
print(True and False)
print(True or False)
print(not False)
print(0 or "fallback")
print("value" and 123)

# short-circuit: should not call missing name
print(False and missing_name)
print(True or missing_name)
