# Group 1: modulo, bitwise, augmented assignment, chained comparison
# modulo
print(7 % 3)
print(-7 % 3)
print(7 % -3)
print(10 % 5)
print(7.5 % 2)
# bitwise
print(6 & 3)
print(6 | 1)
print(6 ^ 3)
print(~5)
print(1 << 4)
print(256 >> 2)
# precedence: | < ^ < & < shift < + < *
print(1 | 2 & 3)
print(2 + 3 * 4)
print(1 << 2 + 1)
print(5 & 3 | 4)
# augmented assignment
a = 17
a %= 5
print(a)
b = 2
b **= 10
print(b)
c = 17
c //= 5
print(c)
d = 6
d &= 3
print(d)
e = 5
e |= 2
print(e)
f = 5
f ^= 1
print(f)
g = 1
g <<= 8
print(g)
h = 1024
h >>= 3
print(h)
# chained comparison
print(1 < 2 < 3)
print(3 < 2 < 1)
print(1 < 3 < 2)
print(1 == 1 == 1)
print(1 <= 1 < 2 <= 2)
print(5 > 4 > 3 > 2)
print(5 > 4 > 6)
